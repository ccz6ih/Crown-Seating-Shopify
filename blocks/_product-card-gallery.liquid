{%- liquid
  assign product = closest.product
  assign has_video = false
  assign product_video = null
  unless product == blank
    for media in product.media
      if media.media_type == 'video'
        assign has_video = true
        assign product_video = media
        break
      endif
    endfor
  endunless
-%}

{% capture children %}
  {% unless product == blank %}
    {% render 'product-card-badges', product: product %}
    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add', product: product, section_id: section.id %}
    {% endif %}
  {% endunless %}
{% endcapture %}

<div
  class="card-gallery"
  style="
    --image-ratio: {{ block.settings.image_ratio }};
    --border-width: {{ block.settings.border_width }}px;
    --border-opacity: {{ block.settings.border_opacity | divided_by: 100.0 }};
    --border-radius: {{ block.settings.border_radius }}px;
    --padding-block-start: {{ block.settings.padding-block-start }}px;
    --padding-block-end: {{ block.settings.padding-block-end }}px;
    --padding-inline-start: {{ block.settings.padding-inline-start }}px;
    --padding-inline-end: {{ block.settings.padding-inline-end }}px;
    {% if block.settings.border != 'none' %}
      border-style: {{ block.settings.border }};
    {% endif %}
  "
>
  {% if has_video and product_video != null %}
    {% comment %}
      Video card: Shows poster image by default (clickable for product navigation).
      Play button overlays the poster - clicking it swaps in the actual video.
      This keeps the card clickable while still allowing video playback.
    {% endcomment %}
    {% liquid
      assign poster_url = null
      if product_video.preview_image != null and product_video.preview_image != blank
        assign poster_url = product_video.preview_image | image_url: width: 600
      elsif product.featured_image != null and product.featured_image != blank
        assign poster_url = product.featured_image | image_url: width: 600
      endif
    %}

    <div class="product-card-video-wrap" data-product-url="{{ product.url }}">
      {% if poster_url != null %}
        <img
          src="{{ poster_url }}"
          alt="{{ product.title | escape }}"
          class="product-card-video__poster"
          loading="lazy"
        >
      {% endif %}
      <button
        type="button"
        class="product-card-video__play-btn"
        aria-label="Play video for {{ product.title | escape }}"
        data-video-sources="{{ product_video.sources | map: 'url' | join: ',' }}"
        data-video-type="{{ product_video.sources[0].mime_type }}"
      >
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
          <circle cx="24" cy="24" r="23" fill="rgba(0,0,0,0.5)" stroke="white" stroke-width="2"/>
          <polygon points="19,14 36,24 19,34" fill="white"/>
        </svg>
      </button>
    </div>
  {% else %}
    {% if product != blank and product.featured_image %}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | escape }}"
        style="width: 100%; height: 100%; object-fit: cover;"
        loading="lazy"
      >
    {% else %}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  {% endif %}
  {{ children }}
</div>

{% # Title and price for the zoomed out grid view %}
<div class="product-grid-view-zoom-out--details">
  {% if product == blank %}
    <h3 class="h4">{{ 'content.product_card_placeholder' | t }}</h3>
  {% else %}
    <h3 class="h4">{{ product.title }}</h3>
    <div class="h6">
      <product-price data-product-id="{{ product.id }}">
        {% render 'price', product_resource: product, show_unit_price: false %}
      </product-price>
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('click', function(e) {
    var playBtn = e.target.closest('.product-card-video__play-btn');
    if (!playBtn) return;

    e.preventDefault();
    e.stopPropagation();

    var wrap = playBtn.closest('.product-card-video-wrap');
    if (!wrap) return;

    var sources = playBtn.dataset.videoSources;
    var mimeType = playBtn.dataset.videoType || 'video/mp4';
    if (!sources) return;

    var sourceUrl = sources.split(',')[0];
    var video = document.createElement('video');
    video.className = 'product-card-video';
    video.controls = true;
    video.playsinline = true;
    video.autoplay = true;
    video.style.cssText = 'width:100%;height:100%;object-fit:cover;';

    var source = document.createElement('source');
    source.src = sourceUrl;
    source.type = mimeType;
    video.appendChild(source);

    // Stop clicks on the playing video from navigating
    video.addEventListener('click', function(ev) {
      ev.stopPropagation();
    });

    wrap.innerHTML = '';
    wrap.appendChild(video);
  });
</script>

{% stylesheet %}
  .product-card-video-wrap {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .product-card-video__poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-card-video__play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 2;
    opacity: 0.85;
    transition: opacity 0.2s;
  }

  .product-card-video__play-btn:hover {
    opacity: 1;
  }

  .product-card-video-wrap .product-card-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_image",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_media"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "portrait",
      "label": "t:settings.aspect_ratio",
      "info": "t:info.aspect_ratio_adjusted"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_card_media",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
