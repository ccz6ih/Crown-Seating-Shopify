{%- liquid
  assign product = closest.product
  assign has_video = false
  assign product_video = null
  unless product == blank
    for media in product.media
      if media.media_type == 'video'
        assign has_video = true
        assign product_video = media
        break
      endif
    endfor
  endunless
-%}

{% capture children %}
  {% unless product == blank %}
    {% render 'product-card-badges', product: product %}
    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add', product: product, section_id: section.id %}
    {% endif %}
  {% endunless %}
{% endcapture %}

<div
  class="card-gallery"
  style="
    --image-ratio: {{ block.settings.image_ratio }};
    --border-width: {{ block.settings.border_width }}px;
    --border-opacity: {{ block.settings.border_opacity | divided_by: 100.0 }};
    --border-radius: {{ block.settings.border_radius }}px;
    --padding-block-start: {{ block.settings.padding-block-start }}px;
    --padding-block-end: {{ block.settings.padding-block-end }}px;
    --padding-inline-start: {{ block.settings.padding-inline-start }}px;
    --padding-inline-end: {{ block.settings.padding-inline-end }}px;
    {% if block.settings.border != 'none' %}
      border-style: {{ block.settings.border }};
    {% endif %}
  "
>
  {% if has_video and product_video != null %}
    {% comment %} Use Shopify's video_tag with proper poster handling - prioritize video's cover image {% endcomment %}
    {% liquid
      assign poster_url = null
      if product_video.preview_image != null and product_video.preview_image != blank
        assign poster_url = product_video.preview_image | image_url: width: 600
      elsif product.featured_image != null and product.featured_image != blank
        assign poster_url = product.featured_image | image_url: width: 600
      endif
    %}

    <div class="product-card-video-wrap" style="position: relative; width: 100%; height: 100%;">
      {% if poster_url != null %}
        {{
          product_video
          | video_tag:
            autoplay: false,
            muted: false,
            loop: false,
            playsinline: true,
            controls: true,
            poster: poster_url,
            class: 'product-card-video',
            style: 'width: 100%; height: 100%; object-fit: cover;'
        }}
      {% else %}
        {{
          product_video
          | video_tag:
            autoplay: false,
            muted: false,
            loop: false,
            playsinline: true,
            controls: true,
            class: 'product-card-video',
            style: 'width: 100%; height: 100%; object-fit: cover;'
        }}
      {% endif %}
      <a
        href="{{ product.url }}"
        class="product-card-video__link"
        aria-label="View {{ product.title | escape }}"
      >
        View Product
      </a>
    </div>
  {% else %}
    {% if product != blank and product.featured_image %}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | escape }}"
        style="width: 100%; height: 100%; object-fit: cover;"
        loading="lazy"
      >
    {% else %}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  {% endif %}
  {{ children }}
</div>

{% # Title and price for the zoomed out grid view %}
<div class="product-grid-view-zoom-out--details">
  {% if product == blank %}
    <h3 class="h4">{{ 'content.product_card_placeholder' | t }}</h3>
  {% else %}
    <h3 class="h4">{{ product.title }}</h3>
    <div class="h6">
      <product-price data-product-id="{{ product.id }}">
        {% render 'price', product_resource: product, show_unit_price: false %}
      </product-price>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .product-card-video__link {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.03em;
    z-index: 3;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .product-card-video-wrap:hover .product-card-video__link {
    opacity: 1;
  }

  .product-card-video__link:hover {
    background: rgba(0, 0, 0, 0.9);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_image",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_media"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "portrait",
      "label": "t:settings.aspect_ratio",
      "info": "t:info.aspect_ratio_adjusted"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_card_media",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
