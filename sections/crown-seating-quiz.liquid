    // Ergonomic Height Optimization (25 points) - Crown Seating's Precision Engineering
    const heightMap = {
      'Under 5\'4" - Petite': 'small',
      '5\'4" - 5\'10" - Average': 'medium',
      'Over 5\'10" - Tall': 'tall'
    };
    const userHeightCategory = heightMap[answers.height] || 'medium';
    
    if (product.heightCategory.includes(userHeightCategory)) {
      score += 25;
      const heightMessages = {
        'small': 'Ergonomically engineered for petite professionals - Crown Seating\'s precision height adjustments ensure optimal 90-110° thigh-to-torso angle',
        'medium': 'Perfect ergonomic fit for your height - Crown Seating\'s research-backed design reduces spinal compression by up to 40%',
        'tall': 'Specially designed for taller professionals - Crown Seating\'s extended height range maintains proper posture during long procedures'
      };
      reasons.push(heightMessages[userHeightCategory]);
    } else {
      deductions.push('Height range may not provide optimal ergonomic positioning');
      score -= 5;
    }

    // Professional Role Alignment (25 points) - Crown Seating's Clinical Expertise
    const isAssistantRole = answers.role === 'Dental Assistant';
    const isAssistantProduct = product.type === 'assistant';
    
    if ((isAssistantRole && isAssistantProduct) || (!isAssistantRole && !isAssistantProduct)) {
      score += 25;
      const roleMessages = {
        'operator': `Engineered for ${answers.role} - Crown Seating's operator models feature enhanced lumbar support and stability for precision procedures`,
        'assistant': 'Designed for dental assistants - Crown Seating\'s assistant models prioritize mobility and quick adjustments for dynamic workflow support'
      };
      reasons.push(roleMessages[product.type] || `Professionally designed for ${product.type} use`);
    } else if (answers.role === 'Multiple Roles') {
      score += 15; // Partial points for versatility
      reasons.push('Crown Seating\'s versatile design accommodates multiple professional roles with adaptive ergonomics');
    } else {
      deductions.push('Role specialization may not align with your primary function');
      score -= 10;
    }

    // Seating Style Biomechanics (20 points) - Crown Seating's Ergonomic Innovation
    const styleMap = {
      'Traditional Round': 'traditional',
      'Saddle Style': 'saddle',
      'Hybrid/Ergonomic': 'hybrid',
      'Open to Recommendations': 'any'
    };
    const userStyle = styleMap[answers.style] || 'traditional';
    
    if (userStyle === 'any' || userStyle === product.style) {
      score += 20;
      const styleMessages = {
        'traditional': 'Crown Seating\'s traditional design - clinically proven comfort with superior lumbar support and familiar positioning',
        'saddle': 'Crown Seating\'s saddle innovation - reduces lower back pressure by 40% and improves spinal alignment for healthier sitting',
        'hybrid': 'Crown Seating\'s hybrid technology - combines traditional comfort with advanced ergonomic benefits for optimal positioning'
      };
      reasons.push(styleMessages[product.style] || `${product.style.charAt(0).toUpperCase() + product.style.slice(1)} style biomechanics`);
    } else if ((userStyle === 'hybrid' && product.style === 'saddle') || 
               (userStyle === 'saddle' && product.style === 'hybrid')) {
      score += 12; // Partial compatibility
      reasons.push('Crown Seating\'s ergonomic design philosophy aligns with your biomechanical preferences');
    } else {
      deductions.push('Seating style may not match your ergonomic preferences');
