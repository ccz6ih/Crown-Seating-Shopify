            }
            break;
          case 'Larger Seat Dimensions':
            if (product.seatWidth >= 19 || product.features.some(f => f.includes('Large seat'))) {
              needsBonus += 5;
              reasons.push('Crown Seating\'s oversized seat design - 20"+ width provides superior comfort for extended procedures');
            }
            break;
          case 'Pressure Point Relief':
            if (product.features.some(f => f.includes('Pressure relief')) || product.style === 'saddle') {
              needsBonus += 4;
              reasons.push('Crown Seating\'s pressure-relief technology - distributes body weight evenly to eliminate hot spots');
            }
            break;
          case 'Quick Height Adjustments':
            if (product.features.some(f => f.includes('Quick adjustments'))) {
              needsBonus += 3;
              reasons.push('Crown Seating\'s rapid-adjust mechanism - seamless height changes without interrupting workflow');
            }
            break;
          case 'Enhanced Mobility':
            if (product.features.some(f => f.includes('Mobile design'))) {
              needsBonus += 3;
              reasons.push('Crown Seating\'s premium caster system - smooth, silent movement between operatories');
            }
            break;
        }
      });
      
      score += Math.min(15, needsBonus); // Cap at 15 points
    }

    // Crown Seating Innovation Bonus (up to 10 points) - Industry Leadership Recognition
    let innovationBonus = 0;
    
    // Premium series bonus
    if (['Denver', 'Telluride', 'Pinnacle'].includes(product.series)) {
      innovationBonus += 5;
      reasons.push('Crown Seating\'s flagship series - representing 25+ years of ergonomic innovation and industry leadership');
    }
    
    // High-performance features bonus
    if (product.features.includes('High performance')) {
      innovationBonus += 3;
      reasons.push('Crown Seating\'s high-performance engineering - trusted by dental professionals worldwide');
    }
    
    // Professional comfort certification
    if (product.features.includes('Professional comfort')) {
      innovationBonus += 2;
      reasons.push('Crown Seating\'s professional comfort certification - meeting the highest ergonomic standards');
    }
    
    score += Math.min(10, innovationBonus); // Cap at 10 points

    scored.push({
      handle,
      product,
      score: Math.min(100, Math.max(0, score)), // Cap at 100
      reasons: reasons.slice(0, 4), // Limit to top 4 reasons
      deductions
    });
  }

  // Sort by score and return top recommendations
  scored.sort((a, b) => b.score - a.score);
  
  // Return top 3 recommendations
  return scored.slice(0, 3);
}

