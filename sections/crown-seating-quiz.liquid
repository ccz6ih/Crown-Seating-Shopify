  Enhanced Professional Crown Seating Quiz with Real Product Integration
  Version: 4.0 - Optimized with BodyType Focus (Removed Weight)
{% endcomment %}

{{ 'crown-seating-quiz.css' | asset_url | stylesheet_tag }}
{{ 'quiz-analytics.js' | asset_url | script_tag }}
{{ 'hubspot-integration.js' | asset_url | script_tag }}

<div class="crown-seating-quiz-wrapper" id="section-{{ section.id }}">
  <div class="container">
    <!-- Trust Indicators -->
    <div class="trust-indicators">
      <h3>🏆 Trusted by Dental Professionals Worldwide</h3>
      <div class="trust-stats">
        <div class="trust-stat">
          <h4>25+</h4>
          <p>Years of Experience</p>
        </div>
        <div class="trust-stat">
          <h4>48</h4>
          <p>Professional Models</p>
        </div>
        <div class="trust-stat">
          <h4>10K+</h4>
          <p>Satisfied Dentists</p>
        </div>
        <div class="trust-stat">
          <h4>5⭐</h4>
          <p>Average Rating</p>
        </div>
      </div>
    </div>

    <!-- Quiz Header -->
    <div class="quiz-header">
      <div class="logo-area">
        <h1>{{ section.settings.heading | default: 'Crown Seating Professional Quiz' }}</h1>
        <h2>{{ section.settings.subheading | default: 'Find Your Perfect Dental Stool' }}</h2>
      </div>
      <p>
        {{
          section.settings.description
          | default: 'Get personalized recommendations from our 48-model lineup. This comprehensive assessment analyzes your height, role, workspace, and ergonomic needs to match you with the ideal Crown Seating solution.'
        }}
      </p>
      <div class="progress-container">
        <div class="progress-fill" id="progressBar"></div>
        <div class="progress-text" id="progressText">0% Complete</div>
      </div>
    </div>

    <form id="seatingQuiz">
      <!-- Question 1: Height & Body Measurements -->
      <div class="question-card active" data-question="1">
        <div class="question-header">
          <div class="question-number">1</div>
          <div class="question">What is your height range?</div>
        </div>

        <div class="health-impact">
          <h4>🔬 Ergonomic Science</h4>
          <p>
            Proper seat height is crucial for maintaining the ideal 90-110° thigh-to-torso angle, reducing spinal
            compression by up to 40% during procedures.
          </p>
        </div>

        <div class="height-visualization">
          <h4>Height-Based Seating Requirements:</h4>
          <div class="height-categories">
            <div class="height-category small">
              <h5>PETITE (Under 5'4")</h5>
              <p>
                • Requires lower minimum heights<br>
                • Smaller seat dimensions<br>
                • Closer reach adjustments
              </p>
            </div>
            <div class="height-category medium">
              <h5>AVERAGE (5'4" - 5'10")</h5>
              <p>
                • Standard height ranges<br>
                • Most model compatibility<br>
                • Balanced proportions
              </p>
            </div>
            <div class="height-category tall">
              <h5>TALL (Over 5'10")</h5>
              <p>
                • Extended height ranges<br>
                • Larger seat dimensions<br>
                • Enhanced stability features
              </p>
            </div>
          </div>
        </div>

        <div class="options">
          <label class="option">
            <input type="radio" name="height" value="Under 5'4" - Petite" required>
            <span class="option-text">Under 5'4" - Petite frame requiring optimized ergonomics</span>
            <span class="option-benefit">Best with compact, lower-profile models</span>
          </label>
          <label class="option">
            <input type="radio" name="height" value="5'4" - 5'10" - Average" required>
            <span class="option-text">5'4" - 5'10" - Average height with standard requirements</span>
            <span class="option-benefit">Compatible with our full model range</span>
          </label>
          <label class="option">
            <input type="radio" name="height" value="Over 5'10" - Tall" required>
            <span class="option-text">Over 5'10" - Tall stature needing extended features</span>
            <span class="option-benefit">Requires higher adjustments and larger seats</span>
          </label>
        </div>
      </div>

      <!-- Question 2: Professional Role & Specialization -->
      <div class="question-card" data-question="2">
        <div class="question-header">
          <div class="question-number">2</div>
          <div class="question">What is your primary dental profession?</div>
        </div>

        <div class="cost-benefit">
          <h4>💼 Role-Specific Requirements</h4>
          <p>
            Different dental roles have unique ergonomic needs. Operators need stability and support for precision work,
            while assistants require mobility and quick adjustments.
          </p>
        </div>

        <div class="role-comparison">
          <div class="role-stats">
            <div class="stat-item">
              <h5>Daily Usage</h5>
              <p>
                Operators: 6-8 hours<br>
                Assistants: 4-6 hours
              </p>
            </div>
            <div class="stat-item">
              <h5>Movement Frequency</h5>
              <p>
                Operators: Low<br>
                Assistants: High
              </p>
            </div>
            <div class="stat-item">
              <h5>Position Stability</h5>
              <p>
                Operators: Critical<br>
                Assistants: Moderate
              </p>
            </div>
          </div>
        </div>

        <div class="options">
          <label class="option">
            <input type="radio" name="role" value="General Dentist" required>
            <span class="option-text">General Dentist - Primary operator requiring stable, comfortable positioning</span>
            <span class="option-benefit">Operator models with enhanced lumbar support</span>
          </label>
          <label class="option">
            <input type="radio" name="role" value="Specialist (Endo/Perio/Oral Surgery)" required>
            <span class="option-text">Specialist (Endo, Perio, Oral Surgeon) - Extended procedure comfort</span>
            <span class="option-benefit">Premium models with advanced ergonomics</span>
          </label>
          <label class="option">
            <input type="radio" name="role" value="Dental Hygienist" required>
            <span class="option-text">Dental Hygienist - Long-session operator with repetitive motions</span>
            <span class="option-benefit">Operator models with superior cushioning</span>
          </label>
          <label class="option">
            <input type="radio" name="role" value="Dental Assistant" required>
            <span class="option-text">Dental Assistant - Mobile support role with frequent adjustments</span>
            <span class="option-benefit">Assistant models with quick-adjust mechanisms</span>
          </label>
          <label class="option">
            <input type="radio" name="role" value="Multiple Roles" required>
            <span class="option-text">Multiple Roles - Need versatility across different functions</span>
            <span class="option-benefit">Adaptable models suitable for various tasks</span>
          </label>
        </div>
      </div>

      <!-- Question 3: Seating Style Preference -->
      <div class="question-card" data-question="3">
        <div class="question-header">
          <div class="question-number">3</div>
          <div class="question">What seating style do you prefer or want to try?</div>
        </div>

        <div class="health-impact">
          <h4>🏥 Clinical Research Findings</h4>
          <p>
            Saddle seating can reduce lower back pressure by 40% and improve spinal alignment, while traditional seating
            offers familiar comfort with excellent support options.
          </p>
        </div>

        <div class="style-comparison">
          <div class="style-grid">
            <div class="style-item traditional">
              <h5>Traditional Round (31 models)</h5>
              <div class="pros-cons">
                <div class="pros">
                  <h6>✅ Benefits:</h6>
                  <ul>
                    <li>Familiar, comfortable feel</li>
                    <li>Excellent lumbar support options</li>
                    <li>Wide variety of models</li>
                    <li>Easy transition from office chairs</li>
                  </ul>
                </div>
                <div class="cons">
                  <h6>⚠️ Considerations:</h6>
                  <ul>
                    <li>May increase pressure on tailbone</li>
                    <li>Less optimal for forward leaning</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="style-item saddle">
              <h5>Saddle Style (16 models)</h5>
              <div class="pros-cons">
                <div class="pros">
                  <h6>✅ Benefits:</h6>
                  <ul>
                    <li>Improves spinal alignment</li>
                    <li>Reduces pressure points</li>
                    <li>Better for forward-leaning procedures</li>
                    <li>Promotes active sitting</li>
                  </ul>
                </div>
                <div class="cons">
                  <h6>⚠️ Considerations:</h6>
                  <ul>
                    <li>Adjustment period required</li>
                    <li>May feel unfamiliar initially</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="style-item hybrid">
              <h5>Hybrid/Ergonomic (1 model)</h5>
              <div class="pros-cons">
                <div class="pros">
                  <h6>✅ Benefits:</h6>
                  <ul>
                    <li>Combines traditional comfort with ergonomic benefits</li>
                    <li>Versatile positioning options</li>
                    <li>Easier transition than full saddle</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="options">
          <label class="option">
            <input type="radio" name="style" value="Traditional Round" required>
            <span class="option-text">Traditional Round - Familiar comfort with excellent support</span>
            <span class="option-benefit">Largest selection with 31 models available</span>
          </label>
          <label class="option">
            <input type="radio" name="style" value="Saddle Style" required>
            <span class="option-text">Saddle Style - Ergonomic benefits for spinal health</span>
            <span class="option-benefit">16 specialized models for improved posture</span>
          </label>
          <label class="option">
            <input type="radio" name="style" value="Hybrid/Ergonomic" required>
            <span class="option-text">Hybrid/Ergonomic - Best of both worlds</span>
            <span class="option-benefit">Unique design combining benefits</span>
          </label>
          <label class="option">
            <input type="radio" name="style" value="Open to Recommendations" required>
            <span class="option-text">Open to Recommendations - Let science guide my choice</span>
            <span class="option-benefit">We'll recommend based on your other preferences</span>
          </label>
        </div>
      </div>

      <!-- Question 4: Practice Environment -->
      <div class="question-card" data-question="4">
        <div class="question-header">
          <div class="question-number">4</div>
          <div class="question">Describe your practice environment:</div>
        </div>

        <div class="cost-benefit">
          <h4>🏢 Practice-Specific Considerations</h4>
          <p>
            Different environments require different durability, adjustability, and standardization levels. Solo
            practices can optimize for individual needs, while larger practices need versatile solutions.
          </p>
        </div>

        <div class="options">
          <label class="option">
            <input type="radio" name="practice_type" value="Solo Practice" required>
            <span class="option-text">Solo Practice - Single doctor, can personalize choices</span>
            <span class="option-benefit">Premium models optimized for your specific needs</span>
          </label>
          <label class="option">
            <input type="radio" name="practice_type" value="Small Group (2-4 doctors)" required>
            <span class="option-text">Small Group (2-4 doctors) - Need versatile solutions</span>
            <span class="option-benefit">Adaptable models accommodating multiple users</span>
          </label>
          <label class="option">
            <input type="radio" name="practice_type" value="Large Practice (5+ doctors)" required>
            <span class="option-text">Large Practice (5+ doctors) - Require standardization</span>
            <span class="option-benefit">Durable, consistent models for multiple operators</span>
          </label>
          <label class="option">
            <input type="radio" name="practice_type" value="DSO/Corporate" required>
            <span class="option-text">DSO/Corporate - Multiple locations, bulk needs</span>
            <span class="option-benefit">Proven models with consistent quality and value</span>
          </label>
          <label class="option">
            <input type="radio" name="practice_type" value="Mobile/Satellite Clinic" required>
            <span class="option-text">Mobile/Satellite Clinic - Portability important</span>
            <span class="option-benefit">Lighter, more portable model options</span>
          </label>
        </div>
      </div>

      <!-- Question 5: Daily Usage & Intensity -->
      <div class="question-card" data-question="5">
        <div class="question-header">
          <div class="question-number">5</div>
          <div class="question">How intensively will you use your seating daily?</div>
        </div>

        <div class="health-impact">
          <h4>⏰ Usage Impact on Investment</h4>
          <p>
            Heavy daily use (6+ hours) significantly benefits from premium cushioning and adjustability features. The
            cost-per-hour over a stool's 10+ year lifespan makes quality investment worthwhile.
          </p>
        </div>

        <div class="usage-calculator">
          <h4>Return on Investment Calculator:</h4>
          <div class="roi-grid">
            <div class="roi-item">
              <h5>Light Use (2-4 hours)</h5>
              <p>$0.50-1.00 per hour over 10 years</p>
            </div>
            <div class="roi-item">
              <h5>Moderate Use (4-6 hours)</h5>
              <p>$0.25-0.75 per hour over 10 years</p>
            </div>
            <div class="roi-item">
              <h5>Heavy Use (6-8+ hours)</h5>
              <p>$0.15-0.50 per hour over 10 years</p>
            </div>
          </div>
        </div>

        <div class="options">
          <label class="option">
            <input type="radio" name="usage_intensity" value="Light (2-4 hours)" required>
            <span class="option-text">Light Use (2-4 hours daily) - Part-time or occasional use</span>
            <span class="option-benefit">Entry to mid-level models provide excellent value</span>
          </label>
          <label class="option">
            <input type="radio" name="usage_intensity" value="Moderate (4-6 hours)" required>
            <span class="option-text">Moderate Use (4-6 hours daily) - Standard full-time practice</span>
            <span class="option-benefit">Mid to premium models for comfort and durability</span>
          </label>
          <label class="option">
            <input type="radio" name="usage_intensity" value="Heavy (6-8 hours)" required>
            <span class="option-text">Heavy Use (6-8 hours daily) - Full-time with long procedures</span>
            <span class="option-benefit">Premium models with advanced ergonomics essential</span>
          </label>
          <label class="option">
            <input type="radio" name="usage_intensity" value="Intensive (8+ hours)" required>
            <span class="option-text">Intensive Use (8+ hours daily) - Extended sessions, multiple procedures</span>
            <span class="option-benefit">Top-tier models with maximum comfort features</span>
          </label>
        </div>
      </div>

      <!-- Question 6: Specific Ergonomic Needs -->
      <div class="question-card" data-question="6">
        <div class="question-header">
          <div class="question-number">6</div>
          <div class="question">Do you have specific ergonomic needs? (Select all that apply)</div>
        </div>

        <div class="health-impact">
          <h4>🎯 Targeted Ergonomic Solutions</h4>
          <p>
            Specific features can address individual comfort needs and prevent musculoskeletal issues. Each feature is
            designed to solve common problems dental professionals face.
          </p>
        </div>

        <div class="options checkbox-options">
          <label class="option">
            <input type="checkbox" name="needs" value="Enhanced Back/Lumbar Support">
            <span class="option-text">Enhanced Back/Lumbar Support - For spinal alignment</span>
            <span class="option-benefit">Available in 12+ models with various back configurations</span>
          </label>
          <label class="option">
            <input type="checkbox" name="needs" value="Larger Seat Dimensions">
            <span class="option-text">Larger Seat Dimensions - For additional comfort</span>
            <span class="option-benefit">Large seat models accommodate broader body types</span>
          </label>
          <label class="option">
            <input type="checkbox" name="needs" value="Quick Height Adjustments">
            <span class="option-text">Quick Height Adjustments - For efficiency between patients</span>
            <span class="option-benefit">Pneumatic and lever systems for rapid changes</span>
          </label>
          <label class="option">
            <input type="checkbox" name="needs" value="Enhanced Mobility">
            <span class="option-text">Enhanced Mobility - For moving between operatories</span>
            <span class="option-benefit">High-quality casters and lightweight designs</span>
          </label>
          <label class="option">
            <input type="checkbox" name="needs" value="Easy Cleaning/Infection Control">
            <span class="option-text">Easy Cleaning/Infection Control - Seamless upholstery</span>
            <span class="option-benefit">Medical-grade materials and seamless construction</span>
          </label>
          <label class="option">
            <input type="checkbox" name="needs" value="Pressure Point Relief">
            <span class="option-text">Pressure Point Relief - For circulation and comfort</span>
            <span class="option-benefit">Memory foam and gel cushioning options</span>
          </label>
          <label class="option">
            <input type="checkbox" name="needs" value="Armrest Support">
            <span class="option-text">Armrest Support - For procedure stability</span>
            <span class="option-benefit">Adjustable armrests on select assistant models</span>
          </label>
          <label class="option">
            <input type="checkbox" name="needs" value="No Specific Needs">
            <span class="option-text">No Specific Needs - Standard comfort is sufficient</span>
            <span class="option-benefit">Focus on core functionality and value</span>
          </label>
        </div>
      </div>

 <!-- Question 7: Body Type & Support Preferences -->
<div class="question-card" data-question="7">
  <div class="question-header">
    <div class="question-number">7</div>
    <div class="question">What body type best describes your support preferences?</div>
  </div>

  <div class="health-impact">
    <h4>⚖️ Ergonomic Fit & Comfort Engineering</h4>
    <p>
      Different body types require different seat sizes, support levels, and stability features. Choosing the right fit ensures optimal comfort, proper posture, and long-term durability for your investment.
    </p>
  </div>

  <div class="bodytype-comparison">
    <div class="bodytype-grid">
      <div class="bodytype-item petite">
        <h5>🌸 Petite/Lightweight Build</h5>
        <div class="bodytype-details">
          <p><strong>Optimal Features:</strong></p>
          <ul>
            <li>Compact seat dimensions (16-17")</li>
            <li>Lower cylinder height ranges</li>
            <li>Lighter overall construction</li>
            <li>Easier maneuverability</li>
          </ul>
        </div>
      </div>
      
      <div class="bodytype-item average">
        <h5>👤 Average Build</h5>
        <div class="bodytype-details">
          <p><strong>Optimal Features:</strong></p>
          <ul>
            <li>Standard seat width (17-19")</li>
            <li>Full height adjustment range</li>
            <li>Balanced support and cushioning</li>
            <li>Compatible with most models</li>
          </ul>
        </div>
      </div>
      
      <div class="bodytype-item broad">
        <h5>💪 Larger/Heavy-Duty Build</h5>
        <div class="bodytype-details">
          <p><strong>Optimal Features:</strong></p>
          <ul>
            <li>Wider seats (19"+ width)</li>
            <li>Reinforced frame construction</li>
            <li>Enhanced stability base</li>
            <li>Heavy-duty cylinder mechanisms</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="options">
    <label class="option">
      <input type="radio" name="body_type" value="Petite or Lightweight Build" required>
      <span class="option-text">Petite or Lightweight Build - Compact, agile seating</span>
      <span class="option-benefit">Smaller seats, easier mobility, lighter construction recommended</span>
    </label>

    <label class="option">
      <input type="radio" name="body_type" value="Average Build" required>
      <span class="option-text">Average Build - Standard comfort and adjustability</span>
      <span class="option-benefit">Most models compatible, focus on adjustability and lumbar support</span>
    </label>

    <label class="option">
      <input type="radio" name="body_type" value="Larger Build or Heavy-Duty Needs" required>
      <span class="option-text">Larger Build or Heavy-Duty Needs - Enhanced support and stability</span>
      <span class="option-benefit">Wider seats, reinforced frames, and enhanced stability recommended</span>
    </label>
  </div>
</div>


      <div class="quiz-actions">
        <button type="button" class="prev-btn" id="prevBtn" style="display: none;">← Previous</button>
        <button type="button" class="next-btn" id="nextBtn">Next →</button>
        <button type="button" class="submit-btn" id="submitBtn" style="display: none;">
          Get My Personalized Recommendations 🚀
        </button>
      </div>
    </form>

    <!-- Results Section -->
    <div class="results-section" id="results" style="display: none;">
      <div class="confidence-indicator" id="confidenceIndicator">
        <!-- Confidence score will be inserted here -->
      </div>

      <div class="primary-recommendation" id="primaryRecommendation">
        <!-- Primary recommendation will be inserted here -->
      </div>

      <div class="model-grid" id="modelGrid">
        <!-- Model cards will be inserted here -->
      </div>

      <div class="recommendation-summary" id="recommendationSummary">
        <!-- Summary will be inserted here -->
      </div>
    </div>
  </div>
</div>

