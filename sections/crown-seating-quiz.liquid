function generatePersonalizedMessage(answers, topRec) {
  try {
    // Add comprehensive null checks and default values
    if (!answers || !topRec || !topRec.product) {
      return `Crown Seating's ergonomic expertise has identified your optimal seating solution. This recommendation is based on our proprietary algorithm analyzing 25+ years of clinical data and feedback from over 10,000 dental professionals.`;
    }
    
    const role = (answers.role && typeof answers.role === 'string') ? answers.role : 'dental professional';
    const height = (answers.height && typeof answers.height === 'string') ? answers.height : '';
    const bodyType = (answers.body_type && typeof answers.body_type === 'string') ? answers.body_type : '';
    const usage = (answers.usage_intensity && typeof answers.usage_intensity === 'string') ? answers.usage_intensity : '';
    const practice = (answers.practice_type && typeof answers.practice_type === 'string') ? answers.practice_type : '';
    
    let message = `As a ${role.toLowerCase()}`;
    
    // Add height context with null checks
    if (height && height.includes && height.includes('Petite')) {
      message += ` with a petite frame`;
    } else if (height && height.includes && height.includes('Tall')) {
      message += ` with a taller stature`;
    }
    
    // Add usage context with null checks
    if (usage && usage.includes && usage.includes('Intensive')) {
      message += ` working intensive 8+ hour days`;
    } else if (usage && usage.includes && usage.includes('Heavy')) {
      message += ` with heavy daily usage`;
    }
    
    // Add practice context with null checks
    if (practice === 'Solo Practice') {
      message += ` in your solo practice`;
    } else if (practice && practice.includes && practice.includes('DSO')) {
      message += ` in a corporate dental environment`;
    }
    
    const productName = (topRec.product.name && typeof topRec.product.name === 'string') ? topRec.product.name : 'your recommended Crown Seating model';
    message += `, Crown Seating's ergonomic expertise has identified the ${productName} as your optimal seating solution. This recommendation is based on our proprietary algorithm analyzing 25+ years of clinical data and feedback from over 10,000 dental professionals.`;
    
    return message;
  } catch (error) {
    console.error('Error in generatePersonalizedMessage:', error);
    return `Crown Seating's ergonomic expertise has identified your optimal seating solution. This recommendation is based on our proprietary algorithm analyzing 25+ years of clinical data and feedback from over 10,000 dental professionals.`;
  }
}

function generateStars(count) {
  return '<span class="star">★</span>'.repeat(count) + '<span class="star empty">☆</span>'.repeat(5 - count);
}

function showEmailCaptureForm(answers, recommendations) {
  const emailCaptureHTML = `
    <div class="email-capture-section">
      <h3>📧 Get Your Complete Seating Report</h3>
      <p>Receive detailed specifications, pricing, and exclusive offers for your recommended models.</p>
      
      <form id="emailCaptureForm" class="email-capture-form">
        <div class="form-row">
          <input type="text" name="firstName" placeholder="First Name" required class="form-input">
          <input type="text" name="lastName" placeholder="Last Name" required class="form-input">
        </div>
        <div class="form-row">
          <input type="email" name="email" placeholder="Professional Email" required class="form-input">
          <input type="tel" name="phone" placeholder="Phone (Optional)" class="form-input">
        </div>
        <input type="text" name="practice_name" placeholder="Practice Name" class="form-input-full">
        
        <label class="consent-label">
          <input type="checkbox" name="marketing_consent" required class="consent-checkbox">
          I'd like to receive Crown Seating product information and special offers
        </label>
        
        <button type="submit" class="email-submit-btn">
          Send My Complete Report 📄
        </button>
      </form>
    </div>
  `;
  
  document.getElementById('results').insertAdjacentHTML('beforeend', emailCaptureHTML);
  
  // Handle form submission
  document.getElementById('emailCaptureForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitButton = e.target.querySelector('button[type="submit"]');
    submitButton.innerHTML = 'Sending Report... ⏳';
    submitButton.disabled = true;
    
    const emailFormData = new FormData(e.target);
    const contactData = Object.fromEntries(emailFormData.entries());
    
    // Combine all data for HubSpot
    const fullData = { ...answers, ...contactData };
    
    // Submit to HubSpot
    let success = false;
    if (window.CrownSeatingHubSpot) {
      // Use the HubSpot integration
      const result = await window.CrownSeatingHubSpot.submitQuizToHubSpot(fullData, recommendations);
      success = result.success;
      
      if (!success) {
        console.error('HubSpot submission failed:', result.error);
      }
    } else {
      console.error('HubSpot integration not loaded');
      success = false;
    }
    
    if (success) {
      e.target.innerHTML = `
        <div style="text-align: center; padding: 30px;">
          <h4>✅ Report Sent Successfully!</h4>
          <p>Your personalized Crown Seating report has been sent to <strong>${contactData.email}</strong></p>
          <p>You'll receive:</p>
          <ul style="text-align: left; max-width: 400px; margin: 15px auto;">
            <li>Detailed product specifications</li>
            <li>Pricing and financing options</li>
            <li>Customization possibilities</li>
            <li>Exclusive promotional offers</li>
          </ul>
          <p style="margin-top: 20px; font-size: 0.9em;">A Crown Seating specialist will contact you within 1 business day.</p>
        </div>
      `;
      
      // Track conversion
      if (typeof gtag !== 'undefined') {
        gtag('event', 'email_captured', {
          'event_category': 'Crown Seating Quiz',
          'event_label': 'Quiz Email Capture Success',
          'value': 1
        });
      }
    } else {
      submitButton.innerHTML = '❌ Error - Please Try Again';
      submitButton.disabled = false;
      alert('There was an error submitting your information. Please try again or contact support.');
    }
  });
}
