// Quiz Logic
let currentQuestion = 1;
const totalQuestions = 7; // Updated from 6 to 7
let quizData = {};

// Initialize quiz
document.addEventListener('DOMContentLoaded', function() {
  console.log('Quiz initialization started');
  
  // Set all questions to hidden except first
  document.querySelectorAll('.question-card').forEach((card, index) => {
    if (index === 0) {
      card.classList.add('active');
    } else {
      card.style.display = 'none';
    }
  });
  
  showQuestion(1);
  updateProgress();
  
  // Add event listeners
  const nextBtn = document.getElementById('nextBtn');
  const prevBtn = document.getElementById('prevBtn');
  const submitBtn = document.getElementById('submitBtn');
  
  if (nextBtn) {
    nextBtn.addEventListener('click', function(e) {
      e.preventDefault();
      nextQuestion();
    });
  }
  
  if (prevBtn) {
    prevBtn.addEventListener('click', function(e) {
      e.preventDefault();
      prevQuestion();
    });
  }
  
  if (submitBtn) {
    submitBtn.addEventListener('click', function(e) {
      e.preventDefault();
      console.log('Submit button clicked');
      
      // Force check if button should be enabled
      if (currentQuestion === totalQuestions) {
        const checkboxes = document.querySelectorAll('input[name="needs"]:checked');
        console.log('Checkboxes checked:', checkboxes.length);
        
        if (checkboxes.length > 0) {
          // Force enable and proceed
          submitBtn.disabled = false;
          calculateRecommendation();
        } else {
          alert('Please select at least one ergonomic need option (or "No Specific Needs" if none apply).');
        }
      } else {
        calculateRecommendation();
      }
    });
  }
  
  // Add change listeners to all inputs
  document.querySelectorAll('input[type="radio"], input[type="checkbox"]').forEach(input => {
    input.addEventListener('change', function(e) {
      handleInputChange(e);
    });
  });
});

function handleInputChange(event) {
  const option = event.target.closest('.option');
  
  if (event.target.type === 'radio') {
    // Remove selected class from all options in this question
    const questionCard = event.target.closest('.question-card');
    questionCard.querySelectorAll('.option').forEach(opt => opt.classList.remove('selected'));
    // Add selected class to current option
    option.classList.add('selected');
  } else if (event.target.type === 'checkbox') {
    // Toggle selected class for checkboxes
    option.classList.toggle('selected', event.target.checked);
  }
  
  updateProgress();
  updateNavigationButtons();
}

function showQuestion(questionNum) {
  // Hide all question cards
  document.querySelectorAll('.question-card').forEach(card => {
    card.classList.remove('active');
    card.style.display = 'none';
  });
  
  // Show target question
  const targetCard = document.querySelector(`[data-question="${questionNum}"]`);
  if (targetCard) {
    targetCard.style.display = 'block';
    targetCard.classList.add('active');
    
    // Smooth scroll to question without jumping to top
    setTimeout(() => {
      targetCard.scrollIntoView({ 
        behavior: 'smooth', 
        block: 'center',
        inline: 'nearest'
      });
    }, 100);
  }
  
  currentQuestion = questionNum;
  updateNavigationButtons();
  updateProgress();
}

function updateNavigationButtons() {
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const submitBtn = document.getElementById('submitBtn');
  
  console.log('Updating navigation buttons, current question:', currentQuestion);
  
  if (!prevBtn || !nextBtn || !submitBtn) {
    console.error('Navigation buttons not found');
    return;
  }
  
  // Show/hide previous button
  prevBtn.style.display = currentQuestion > 1 ? 'block' : 'none';
  
  // Show next or submit button
  if (currentQuestion < totalQuestions) {
    nextBtn.style.display = 'block';
    submitBtn.style.display = 'none';
  } else {
    nextBtn.style.display = 'none';
    submitBtn.style.display = 'block';
  }
  
  // Enable/disable based on current question completion
  const currentCard = document.querySelector(`[data-question="${currentQuestion}"]`);
  if (currentCard) {
    let isComplete = false;
    
    if (currentQuestion === 6) {
      // Question 6 is checkboxes - at least one should be checked
      const checkboxInputs = currentCard.querySelectorAll('input[type="checkbox"]');
      isComplete = Array.from(checkboxInputs).some(input => input.checked);
    } else {
      // Other questions are radio buttons
      const requiredInputs = currentCard.querySelectorAll('input[required]');
      isComplete = Array.from(requiredInputs).some(input => input.checked);
    }
    
    nextBtn.disabled = !isComplete;
    submitBtn.disabled = !isComplete;
    
    // Force enable submit button if we're on last question and at least one checkbox is checked
    if (currentQuestion === totalQuestions && isComplete) {
      submitBtn.disabled = false;
      submitBtn.style.opacity = '1';
      submitBtn.style.cursor = 'pointer';
      submitBtn.style.background = 'linear-gradient(135deg, #28a745 0%, #20c997 100%)';
    }
    
    console.log('Question', currentQuestion, 'complete:', isComplete);
  }
}

function nextQuestion() {
  console.log('Next question clicked, current:', currentQuestion);
  
  // Validate current question is answered
  const currentCard = document.querySelector(`[data-question="${currentQuestion}"]`);
  if (!currentCard) return;
  
  let isAnswered = false;
  
  if (currentQuestion === 6) {
    // For checkbox question
    const checkboxes = currentCard.querySelectorAll('input[type="checkbox"]');
    isAnswered = Array.from(checkboxes).some(input => input.checked);
  } else {
    // For radio questions
    const requiredInputs = currentCard.querySelectorAll('input[required]');
    isAnswered = Array.from(requiredInputs).some(input => input.checked);
  }
  
  if (!isAnswered) {
    alert('Please answer the current question before proceeding.');
    return;
  }
  
  if (currentQuestion < totalQuestions) {
    showQuestion(currentQuestion + 1);
  }
}

function prevQuestion() {
  console.log('Previous question clicked, current:', currentQuestion);
  
  if (currentQuestion > 1) {
    showQuestion(currentQuestion - 1);
  }
}

function updateProgress() {
  const answeredQuestions = getAnsweredQuestionCount();
  const progress = (answeredQuestions / totalQuestions) * 100;
  const progressBar = document.getElementById('progressBar');
  const progressText = document.getElementById('progressText');
  
  progressBar.style.width = progress + '%';
  progressText.textContent = Math.round(progress) + '% Complete';
}

function getAnsweredQuestionCount() {
  let count = 0;
  for (let i = 1; i <= totalQuestions; i++) {
    const questionCard = document.querySelector(`[data-question="${i}"]`);
    if (i === 6) {
      // For checkbox question
      const checkboxes = questionCard.querySelectorAll('input[type="checkbox"]');
      if (Array.from(checkboxes).some(input => input.checked)) {
        count++;
      }
    } else {
      // For radio questions
      const requiredInputs = questionCard.querySelectorAll('input[required]');
      if (Array.from(requiredInputs).some(input => input.checked)) {
        count++;
      }
    }
  }
  return count;
}

function calculateRecommendation() {
  console.log('Calculate recommendation triggered');
  
  // Collect form data
  const formData = new FormData(document.getElementById('seatingQuiz'));
  quizData = {};
  
  for (let [key, value] of formData.entries()) {
    if (quizData[key]) {
      if (Array.isArray(quizData[key])) {
        quizData[key].push(value);
      } else {
        quizData[key] = [quizData[key], value];
      }
    } else {
      quizData[key] = value;
    }
  }

  console.log('Quiz data collected:', quizData);

  // Validate required fields
  const requiredFields = ['height', 'role', 'style', 'practice_type', 'usage_intensity', 'body_type'];
  const missingFields = requiredFields.filter(field => !quizData[field]);
  
  if (missingFields.length > 0) {
    alert('Please complete all questions before getting your recommendation. Missing: ' + missingFields.join(', '));
    console.error('Missing fields:', missingFields);
    return;
  }

  // Ensure needs field exists (even if empty)
  if (!quizData.needs) {
    quizData.needs = [];
  }

  console.log('Validation passed, calculating recommendations...');

  // Calculate recommendations
  const recommendations = getPersonalizedRecommendations(quizData);
  console.log('Recommendations calculated:', recommendations);
  
  displayResults(recommendations, quizData);
  
  // Track completion with Google Analytics
  if (typeof gtag !== 'undefined') {
    gtag('event', 'quiz_completed', {
      'event_category': 'Crown Seating Quiz',
      'event_label': 'Enhanced Quiz Completed',
      'value': 1
    });
  }
}

function getPersonalizedRecommendations(answers) {
  // Add error handling and validation
  if (!answers) {
    console.error('No answers provided to getPersonalizedRecommendations');
    return [];
  }
  
  console.log('Quiz answers received:', answers);
  
  const products = Object.entries(crownSeatingDatabase);
  let scored = [];

  /* 
  CROWN SEATING ERGONOMIC PRECISION SCORING™ (Maximum 100 points):
  - Ergonomic Height Optimization: 25 points
  - Professional Role Alignment: 25 points  
  - Seating Style Biomechanics: 20 points
  - Clinical Usage Intensity: 15 points
  - Practice Environment Fit: 10 points
