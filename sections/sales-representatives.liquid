<!-- File: sections/sales-representatives.liquid -->

{{ 'sales-representatives.css' | asset_url | stylesheet_tag }}

<div class="sales-reps-section" data-section-id="{{ section.id }}">
  {% if section.settings.heading != blank %}
    <h2 class="sales-reps-heading">{{ section.settings.heading }}</h2>
  {% endif %}

  {% if section.settings.subheading != blank %}
    <p class="sales-reps-subheading">{{ section.settings.subheading }}</p>
  {% endif %}

  <!-- Search and Filter Controls -->
  <div class="sales-reps-controls">
    <div class="search-container">
      <input
        type="text"
        id="repSearch"
        placeholder="Search by name, territory, state, ZIP code, or phone..."
        class="search-input"
      >
      <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.35-4.35"></path>
      </svg>
    </div>

    <div class="filter-container">
      <select id="territoryFilter" class="territory-filter">
        <option value="">All Territories</option>
        {% assign territories = '' %}
        {% for block in section.blocks %}
          {% if block.settings.territory != blank %}
            {% assign current_territory = block.settings.territory %}
            {% unless territories contains current_territory %}
              {% assign territories = territories | append: current_territory | append: ',' %}
              <option value="{{ current_territory }}">{{ current_territory }}</option>
            {% endunless %}
          {% endif %}
        {% endfor %}
      </select>
    </div>
  </div>

  <!-- Representatives Grid -->
  <div class="sales-reps-grid" id="repsGrid">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'sales_rep' %}
          <div
            class="rep-card"
            data-name="{{ block.settings.name | downcase }}"
            data-territory="{{ block.settings.territory | downcase }}"
            data-phone="{{ block.settings.phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '.' }}"
            data-email="{{ block.settings.email | downcase }}"
            {{ block.shopify_attributes }}
          >
            <div class="rep-photo-container">
              {% if block.settings.photo != blank %}
                <img
                  src="{{ block.settings.photo | image_url: width: 120 }}"
                  alt="{{ block.settings.name }}"
                  class="rep-photo"
                  loading="lazy"
                >
              {% else %}
                <div class="rep-photo-placeholder">
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                  </svg>
                </div>
              {% endif %}
            </div>

            <div class="rep-info">
              <h3 class="rep-name">{{ block.settings.name }}</h3>

              {% if block.settings.territory != blank %}
                <p class="rep-territory">{{ block.settings.territory }}</p>
              {% endif %}

              {% if block.settings.phone != blank %}
                <p class="rep-phone"><strong>Cell:</strong> {{ block.settings.phone }}</p>
              {% endif %}

              {% if block.settings.email != blank %}
                <p class="rep-email"><strong>Email:</strong> {{ block.settings.email }}</p>
              {% endif %}
            </div>

            <div class="rep-actions">
              {% if block.settings.phone != blank %}
                <a
                  href="tel:{{ block.settings.phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '.' }}"
                  class="contact-btn call-btn"
                >
                  📞 Call
                </a>
              {% endif %}

              {% if block.settings.email != blank %}
                <a
                  href="mailto:{{ block.settings.email }}"
                  class="contact-btn email-btn"
                >
                  📧 Email
                </a>
              {% endif %}

              {% if block.settings.phone != blank %}
                <a
                  href="sms:{{ block.settings.phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' | remove: '.' }}"
                  class="contact-btn text-btn"
                >
                  💬 Text
                </a>
              {% endif %}
            </div>
          </div>
      {% endcase %}
    {% endfor %}
  </div>

  <!-- No Results Message -->
  <div class="no-results" id="noResults" style="display: none;">
    <h3>No representatives found</h3>
    <p>Try adjusting your search or filter criteria.</p>
  </div>
</div>

