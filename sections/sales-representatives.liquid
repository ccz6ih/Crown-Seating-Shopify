  // Function to look up rep by ZIP code (handles 3-digit prefixes)
  function getRepByZip(zip) {
    // Remove all non-digits
    const digitsOnly = zip.replace(/\D/g, '');
    
    // Try exact match first (for 3-digit prefixes in our data)
    if (zipToRep[digitsOnly]) {
      return zipToRep[digitsOnly];
    }
    
    // Try first 3 digits (most common case)
    if (digitsOnly.length >= 3) {
      const prefix3 = digitsOnly.substring(0, 3);
      if (zipToRep[prefix3]) {
        return zipToRep[prefix3];
      }
    }
    
    // Try padded version for shorter inputs
    if (digitsOnly.length < 5) {
      const paddedZip = digitsOnly.padStart(5, '0');
      if (zipToRep[paddedZip]) {
        return zipToRep[paddedZip];
      }
    }
    
    return null;
  }

  // Function to expand territory with full state names
  function expandTerritoryWithStates(territory) {
    let expandedTerritory = territory.toLowerCase();
    
    // Find state abbreviations in parentheses or after commas
    Object.keys(stateMapping).forEach(abbrev => {
      const regex = new RegExp('\\b' + abbrev.toLowerCase() + '\\b', 'gi');
      if (expandedTerritory.match(regex)) {
        expandedTerritory += ' ' + stateMapping[abbrev];
      }
    });
    
    return expandedTerritory;
  }

  const searchInput = document.getElementById('repSearch');
  const territoryFilter = document.getElementById('territoryFilter');
  const repsGrid = document.getElementById('repsGrid');
  const noResults = document.getElementById('noResults');
  
  if (!searchInput || !territoryFilter || !repsGrid || !noResults) {
    console.log('Sales rep elements not found');
    return;
  }
  
  const repCards = repsGrid.querySelectorAll('.rep-card');
  console.log('Found', repCards.length, 'rep cards');
  
  // Enhance each card with expanded territory data
  repCards.forEach((card, index) => {
    const originalTerritory = card.dataset.territory || '';
    const expandedTerritory = expandTerritoryWithStates(originalTerritory);
    card.dataset.expandedTerritory = expandedTerritory;
    
    // Debug first few cards
    if (index < 3) {
      console.log(`Card ${index}:`, {
        name: card.dataset.name,
        originalTerritory: originalTerritory,
        expandedTerritory: expandedTerritory.substring(0, 50) + '...'
      });
    }
  });

  function filterReps() {
    const searchTerm = searchInput.value.toLowerCase().trim();
    const selectedTerritory = territoryFilter.value.toLowerCase().trim();
    let visibleCount = 0;

    console.log('Filtering with search:', searchTerm, 'territory:', selectedTerritory);

    // Check if search term is a ZIP code
    const isZipSearch = /^\d{3,5}$/.test(searchTerm);
    let zipMatchRep = null;
    
    if (isZipSearch) {
      zipMatchRep = getRepByZip(searchTerm);
      console.log('ZIP search for', searchTerm, '→', zipMatchRep || 'Not found');
    }

    repCards.forEach((card, index) => {
      const name = card.dataset.name || '';
      const territory = card.dataset.territory || '';
      const expandedTerritory = card.dataset.expandedTerritory || '';
      const phone = card.dataset.phone || '';
      const email = card.dataset.email || '';
      
      // Debug first few cards
      if (index < 2 && searchTerm) {
        console.log(`Card ${index}: checking "${searchTerm}" against:`, {
          name: name,
          zipMatch: zipMatchRep ? (name === zipMatchRep) : false
        });
      }
      
      // Fix phone matching - only match if search has digits
      const searchDigits = searchTerm.replace(/\D/g, '');
      const phoneMatches = searchDigits.length > 0 && phone.includes(searchDigits);
      
      // ZIP code matching
      const zipMatches = zipMatchRep && name === zipMatchRep;
      
      // Check if search term matches any field
      const matchesSearch = !searchTerm || 
                           name.includes(searchTerm) || 
                           territory.includes(searchTerm) || 
                           expandedTerritory.includes(searchTerm) ||
                           phoneMatches ||
                           email.includes(searchTerm) ||
                           zipMatches;
      
      // Check if territory filter matches
      const matchesTerritory = !selectedTerritory || territory.includes(selectedTerritory);
      
      // Debug match results for first few
      if (index < 2 && searchTerm) {
        console.log(`Card ${index} matches:`, {
          nameMatch: name.includes(searchTerm),
          territoryMatch: territory.includes(searchTerm),
          expandedTerritoryMatch: expandedTerritory.includes(searchTerm),
          phoneMatch: phoneMatches,
          emailMatch: email.includes(searchTerm),
          zipMatch: zipMatches,
          overallMatch: matchesSearch && matchesTerritory
        });
      }
      
      if (matchesSearch && matchesTerritory) {
        card.style.display = 'block';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    console.log('Visible cards:', visibleCount);

    // Show/hide no results message
    if (visibleCount === 0) {
      noResults.style.display = 'block';
      repsGrid.style.display = 'none';
    } else {
      noResults.style.display = 'none';  
      repsGrid.style.display = 'grid';
    }
  }

  // Event listeners
  searchInput.addEventListener('input', function(e) {
    console.log('Search input:', e.target.value);
    filterReps();
  });
  
  territoryFilter.addEventListener('change', function(e) {
    console.log('Territory filter:', e.target.value);
    filterReps();
  });

  console.log('Sales rep search initialized with ZIP code lookup (complete data loaded)');
});
</script>

