{"sections":{"main":{"type":"main-page","blocks":{"heading":{"type":"text","name":"Title","settings":{"text":"<h1>{{ closest.page.title }}<\/h1>","width":"100%","max_width":"normal","alignment":"left","type_preset":"h2","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"page-content":{"type":"page-content","settings":{},"blocks":{}}},"block_order":["heading","page-content"],"disabled":true,"settings":{"content_direction":"column","gap":32,"color_scheme":"","padding-block-start":40,"padding-block-end":80}},"custom_liquid_4nHQBQ":{"type":"custom-liquid","disabled":true,"name":"t:names.custom_liquid","settings":{"custom_liquid":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Crown Seating Professional Quiz<\/title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            min-height: 100vh;\n            color: #333;\n        }\n        \n        .container {\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        \n        .quiz-header {\n            text-align: center;\n            background: white;\n            padding: 30px;\n            border-radius: 15px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.1);\n            margin-bottom: 30px;\n        }\n        \n        .logo-area {\n            margin-bottom: 20px;\n        }\n        \n        .quiz-header h1 {\n            color: #2c3e50;\n            font-size: 2.5em;\n            margin-bottom: 10px;\n        }\n        \n        .quiz-header p {\n            color: #7f8c8d;\n            font-size: 1.1em;\n            line-height: 1.6;\n        }\n        \n        .question-card {\n            background: white;\n            border-radius: 15px;\n            padding: 30px;\n            margin-bottom: 20px;\n            box-shadow: 0 8px 25px rgba(0,0,0,0.1);\n            transform: translateY(0);\n            transition: transform 0.3s ease, box-shadow 0.3s ease;\n        }\n        \n        .question-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 15px 35px rgba(0,0,0,0.15);\n        }\n        \n        .question {\n            font-size: 1.3em;\n            font-weight: 600;\n            color: #2c3e50;\n            margin-bottom: 20px;\n        }\n        \n        .options {\n            display: grid;\n            gap: 12px;\n        }\n        \n        .option {\n            display: flex;\n            align-items: center;\n            padding: 15px 20px;\n            border: 2px solid #ecf0f1;\n            border-radius: 10px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            background: #fafafa;\n        }\n        \n        .option:hover {\n            border-color: #3498db;\n            background: #f8f9fa;\n            transform: translateX(5px);\n        }\n        \n        .option.selected {\n            border-color: #3498db;\n            background: linear-gradient(135deg, #3498db, #2980b9);\n            color: white;\n            transform: translateX(5px);\n        }\n        \n        .option input[type=\"radio\"] {\n            margin-right: 15px;\n            transform: scale(1.2);\n        }\n        \n        .option-text {\n            font-size: 1.05em;\n            line-height: 1.4;\n        }\n        \n        .height-guide {\n            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);\n            color: white;\n            padding: 20px;\n            border-radius: 10px;\n            margin: 20px 0;\n            text-align: center;\n        }\n        \n        .height-categories {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n            gap: 15px;\n            margin-top: 15px;\n        }\n        \n        .height-category {\n            background: rgba(255,255,255,0.2);\n            padding: 15px;\n            border-radius: 8px;\n            text-align: center;\n        }\n        \n        .height-category h4 {\n            margin-bottom: 8px;\n            font-size: 1.1em;\n        }\n        \n        .results-section {\n            background: white;\n            border-radius: 15px;\n            padding: 30px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.1);\n            margin-top: 30px;\n            display: none;\n        }\n        \n        .recommendation {\n            background: linear-gradient(135deg, #56ab2f 0%, #a8e6cf 100%);\n            color: white;\n            padding: 25px;\n            border-radius: 10px;\n            margin-bottom: 20px;\n            text-align: center;\n        }\n        \n        .recommendation h3 {\n            font-size: 1.8em;\n            margin-bottom: 10px;\n        }\n        \n        .model-details {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 20px;\n            margin-top: 20px;\n        }\n        \n        .model-card {\n            border: 2px solid #ecf0f1;\n            border-radius: 10px;\n            padding: 20px;\n            background: #fafafa;\n        }\n        \n        .model-card h4 {\n            color: #2c3e50;\n            margin-bottom: 10px;\n            font-size: 1.2em;\n        }\n        \n        .price-tag {\n            background: #e74c3c;\n            color: white;\n            padding: 5px 12px;\n            border-radius: 20px;\n            font-weight: bold;\n            display: inline-block;\n            margin-bottom: 10px;\n        }\n        \n        .features-list {\n            list-style: none;\n            margin-top: 10px;\n        }\n        \n        .features-list li {\n            padding: 5px 0;\n            border-bottom: 1px solid #ecf0f1;\n        }\n        \n        .features-list li:before {\n            content: \"✓ \";\n            color: #27ae60;\n            font-weight: bold;\n        }\n        \n        .submit-btn {\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n            padding: 15px 40px;\n            border: none;\n            border-radius: 10px;\n            font-size: 1.1em;\n            cursor: pointer;\n            display: block;\n            margin: 30px auto;\n            transition: transform 0.3s ease;\n        }\n        \n        .submit-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);\n        }\n        \n        .info-panel {\n            background: #f8f9fa;\n            border-left: 4px solid #3498db;\n            padding: 15px;\n            margin: 15px 0;\n            border-radius: 5px;\n        }\n        \n        .why-section {\n            background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);\n            padding: 20px;\n            border-radius: 10px;\n            margin-top: 20px;\n        }\n        \n        .progress-bar {\n            background: #ecf0f1;\n            height: 8px;\n            border-radius: 4px;\n            margin: 20px 0;\n            overflow: hidden;\n        }\n        \n        .progress-fill {\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            height: 100%;\n            transition: width 0.3s ease;\n        }\n    <\/style>\n<\/head>\n<body>\n    <div class=\"container\">\n        <div class=\"quiz-header\">\n            <div class=\"logo-area\">\n                <h1>Crown Seating<\/h1>\n                <h2>Professional Seating Selection<\/h2>\n            <\/div>\n            <p>Find your perfect dental professional seating solution with our comprehensive assessment. Answer a few questions to get personalized recommendations based on your height, role, and workspace needs.<\/p>\n            <div class=\"progress-bar\">\n                <div class=\"progress-fill\" id=\"progressBar\"><\/div>\n            <\/div>\n        <\/div>\n\n        <form id=\"seatinggQuiz\">\n            <!-- Question 1: Height -->\n            <div class=\"question-card\" data-question=\"1\">\n                <div class=\"question\">What is your height?<\/div>\n                <div class=\"height-guide\">\n                    <h3>Height Categories for Optimal Seating<\/h3>\n                    <div class=\"height-categories\">\n                        <div class=\"height-category\">\n                            <h4>SMALL (S)<\/h4>\n                            <p>Below 5'6\"<\/p>\n                        <\/div>\n                        <div class=\"height-category\">\n                            <h4>MEDIUM (M)<\/h4>\n                            <p>5'4\" - 6'0\"<\/p>\n                        <\/div>\n                        <div class=\"height-category\">\n                            <h4>TALL (T)<\/h4>\n                            <p>Above 5'10\"<\/p>\n                        <\/div>\n                    <\/div>\n                <\/div>\n                <div class=\"options\">\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"height\" value=\"small\">\n                        <span class=\"option-text\">Small (Under 5'6\") - Requires lower seat heights and closer reach adjustments<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"height\" value=\"medium\">\n                        <span class=\"option-text\">Medium (5'4\" - 6'0\") - Standard range with maximum model compatibility<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"height\" value=\"tall\">\n                        <span class=\"option-text\">Tall (Above 5'10\") - Needs extended height range and larger seat dimensions<\/span>\n                    <\/label>\n                <\/div>\n            <\/div>\n\n            <!-- Question 2: Professional Role -->\n            <div class=\"question-card\" data-question=\"2\">\n                <div class=\"question\">What is your primary professional role?<\/div>\n                <div class=\"info-panel\">\n                    <strong>Role-Specific Design:<\/strong> Operator stools prioritize precise positioning and long-duration comfort, while assistant stools focus on mobility and quick adjustments.\n                <\/div>\n                <div class=\"options\">\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"role\" value=\"dentist\">\n                        <span class=\"option-text\">Dentist\/Primary Operator - Requires stable positioning, lumbar support, and precise height control<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"role\" value=\"hygienist\">\n                        <span class=\"option-text\">Dental Hygienist - Needs comfortable long-session seating with excellent ergonomics<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"role\" value=\"assistant\">\n                        <span class=\"option-text\">Dental Assistant - Requires mobile, adjustable seating for multiple positions throughout the day<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"role\" value=\"specialist\">\n                        <span class=\"option-text\">Specialist (Endodontist, Periodontist, etc.) - Needs premium positioning and comfort for complex procedures<\/span>\n                    <\/label>\n                <\/div>\n            <\/div>\n\n            <!-- Question 3: Seating Style Preference -->\n            <div class=\"question-card\" data-question=\"3\">\n                <div class=\"question\">What seating style do you prefer?<\/div>\n                <div class=\"info-panel\">\n                    <strong>Saddle vs Traditional:<\/strong> Saddle seats promote better posture and reduce pressure points, while traditional seats offer familiar comfort with excellent support.\n                <\/div>\n                <div class=\"options\">\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"style\" value=\"saddle\">\n                        <span class=\"option-text\">Saddle Style - Promotes healthy posture, reduces pressure points, better for forward-leaning work<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"style\" value=\"traditional\">\n                        <span class=\"option-text\">Traditional Round - Classic comfort, familiar feel, excellent for extended sitting<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"style\" value=\"hybrid\">\n                        <span class=\"option-text\">Hybrid\/Ergo - Combines benefits of both styles for versatile positioning<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"style\" value=\"no_preference\">\n                        <span class=\"option-text\">No Preference - I'm open to recommendations based on my other needs<\/span>\n                    <\/label>\n                <\/div>\n            <\/div>\n\n            <!-- Question 4: Budget Range -->\n            <div class=\"question-card\" data-question=\"4\">\n                <div class=\"question\">What is your budget range?<\/div>\n                <div class=\"info-panel\">\n                    <strong>Value Tiers:<\/strong> Entry-level models ($500-$800) offer essential features, mid-range ($800-$1500) adds premium adjustments, and premium ($1500+) provides maximum comfort and durability.\n                <\/div>\n                <div class=\"options\">\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"budget\" value=\"entry\">\n                        <span class=\"option-text\">Entry Level ($500 - $800) - Essential features with reliable quality<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"budget\" value=\"mid\">\n                        <span class=\"option-text\">Mid-Range ($800 - $1,500) - Enhanced adjustability and comfort features<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"budget\" value=\"premium\">\n                        <span class=\"option-text\">Premium ($1,500 - $2,000) - Advanced ergonomics and premium materials<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"budget\" value=\"luxury\">\n                        <span class=\"option-text\">Luxury ($2,000+) - Top-tier features, maximum comfort and durability<\/span>\n                    <\/label>\n                <\/div>\n            <\/div>\n\n            <!-- Question 5: Workspace Environment -->\n            <div class=\"question-card\" data-question=\"5\">\n                <div class=\"question\">Describe your primary workspace environment:<\/div>\n                <div class=\"options\">\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"workspace\" value=\"single_op\">\n                        <span class=\"option-text\">Single Operatory - One dedicated workspace, can optimize for specific needs<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"workspace\" value=\"multi_op\">\n                        <span class=\"option-text\">Multiple Operatories - Move between different rooms, need mobility and quick adjustments<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"workspace\" value=\"shared\">\n                        <span class=\"option-text\">Shared Workspace - Multiple users, need versatile adjustability<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"workspace\" value=\"mobile\">\n                        <span class=\"option-text\">Mobile\/Travel - Portable needs, lightweight and easy to transport<\/span>\n                    <\/label>\n                <\/div>\n            <\/div>\n\n            <!-- Question 6: Daily Usage -->\n            <div class=\"question-card\" data-question=\"6\">\n                <div class=\"question\">How many hours per day do you typically use your seating?<\/div>\n                <div class=\"info-panel\">\n                    <strong>Usage Impact:<\/strong> Extended daily use requires premium cushioning, superior lumbar support, and enhanced durability features.\n                <\/div>\n                <div class=\"options\">\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"usage\" value=\"light\">\n                        <span class=\"option-text\">1-3 hours daily - Light use, basic comfort requirements<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"usage\" value=\"moderate\">\n                        <span class=\"option-text\">4-6 hours daily - Moderate use, need good ergonomic support<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"usage\" value=\"heavy\">\n                        <span class=\"option-text\">7-8 hours daily - Heavy use, require premium comfort and durability<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"radio\" name=\"usage\" value=\"intensive\">\n                        <span class=\"option-text\">9+ hours daily - Intensive use, need maximum ergonomic support and premium features<\/span>\n                    <\/label>\n                <\/div>\n            <\/div>\n\n            <!-- Question 7: Specific Needs -->\n            <div class=\"question-card\" data-question=\"7\">\n                <div class=\"question\">Do you have any specific ergonomic needs or preferences? (Select all that apply)<\/div>\n                <div class=\"options\">\n                    <label class=\"option\">\n                        <input type=\"checkbox\" name=\"needs\" value=\"back_support\">\n                        <span class=\"option-text\">Enhanced lumbar\/back support for spinal health<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"checkbox\" name=\"needs\" value=\"arm_support\">\n                        <span class=\"option-text\">Armrests for procedure support and comfort<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"checkbox\" name=\"needs\" value=\"foot_ring\">\n                        <span class=\"option-text\">Adjustable foot ring for leg support<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"checkbox\" name=\"needs\" value=\"wide_seat\">\n                        <span class=\"option-text\">Larger seat dimensions for additional comfort<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"checkbox\" name=\"needs\" value=\"easy_clean\">\n                        <span class=\"option-text\">Easy-to-clean surfaces for infection control<\/span>\n                    <\/label>\n                    <label class=\"option\">\n                        <input type=\"checkbox\" name=\"needs\" value=\"quick_adjust\">\n                        <span class=\"option-text\">Quick adjustment mechanisms for efficiency<\/span>\n                    <\/label>\n                <\/div>\n            <\/div>\n\n            <button type=\"button\" class=\"submit-btn\" onclick=\"calculateRecommendation()\">\n                Get My Personalized Recommendations 🚀\n            <\/button>\n        <\/form>\n\n        <!-- Results Section -->\n        <div class=\"results-section\" id=\"results\">\n            <div class=\"recommendation\" id=\"primaryRecommendation\">\n                <!-- Primary recommendation will be inserted here -->\n            <\/div>\n            \n            <div class=\"model-details\" id=\"modelDetails\">\n                <!-- Model details will be inserted here -->\n            <\/div>\n            \n            <div class=\"why-section\" id=\"whySection\">\n                <!-- Explanation will be inserted here -->\n            <\/div>\n        <\/div>\n    <\/div>\n\n    <script>\n        \/\/ Update progress bar\n        function updateProgress() {\n            const questions = document.querySelectorAll('.question-card');\n            const answeredQuestions = document.querySelectorAll('input[type=\"radio\"]:checked').length;\n            const progress = (answeredQuestions \/ questions.length) * 100;\n            document.getElementById('progressBar').style.width = progress + '%';\n        }\n\n        \/\/ Add event listeners to all radio buttons\n        document.querySelectorAll('input[type=\"radio\"]').forEach(radio => {\n            radio.addEventListener('change', updateProgress);\n        });\n\n        \/\/ Add selection effects\n        document.querySelectorAll('.option').forEach(option => {\n            option.addEventListener('click', function() {\n                const input = this.querySelector('input');\n                if (input.type === 'radio') {\n                    \/\/ Remove selected class from siblings\n                    this.parentElement.querySelectorAll('.option').forEach(opt => {\n                        opt.classList.remove('selected');\n                    });\n                    \/\/ Add selected class to this option\n                    this.classList.add('selected');\n                } else if (input.type === 'checkbox') {\n                    this.classList.toggle('selected');\n                }\n            });\n        });\n\n        \/\/ Product database based on analysis\n        const productDatabase = {\n            'C20D': {\n                name: 'Crestone C20D',\n                price: 513,\n                type: 'operator',\n                style: 'traditional',\n                heightCategory: ['small', 'medium', 'tall'],\n                features: ['Basic adjustments', 'Simple design', 'Cost-effective'],\n                description: 'Comfortable and stylish at a low cost with versatility and mobility.'\n            },\n            'C20A': {\n                name: 'Crestone C20A Assistant',\n                price: 691,\n                type: 'assistant',\n                style: 'traditional',\n                heightCategory: ['small', 'medium', 'tall'],\n                features: ['Assistant-specific design', 'Mobile', 'Dental-friendly'],\n                description: 'Great for mobile dental assistants with comfort and versatility.'\n            },\n            'C30HS': {\n                name: 'Hybrid Saddle C30HS',\n                price: 961,\n                type: 'operator',\n                style: 'hybrid',\n                heightCategory: ['small'],\n                features: ['Posture Perfect design', 'Full tilt adjustment', 'Extra thick cushioning'],\n                description: 'Hybrid saddle seat creates unparalleled comfort with full tilt adjustment.'\n            },\n            'C40D': {\n                name: 'Keystone C40D',\n                price: 1098,\n                type: 'operator',\n                style: 'traditional',\n                heightCategory: ['medium', 'tall'],\n                features: ['Modern functions', 'Classic design', 'Comfortable'],\n                description: 'Classic traditional dental operator stool with modern-day functions and comfort.'\n            },\n            'C40AR': {\n                name: 'Keystone C40AR Round',\n                price: 1337,\n                type: 'operator',\n                style: 'traditional',\n                heightCategory: ['medium', 'tall'],\n                features: ['Traditional round style', 'High resiliency foam', 'Cost-effective'],\n                description: 'Exceptional comfort in a traditional round style with high resiliency foam.'\n            },\n            'C50ABT': {\n                name: 'Assistant Chair C50ABT',\n                price: 2094,\n                type: 'assistant',\n                style: 'traditional',\n                heightCategory: ['small', 'medium'],\n                features: ['Redesigned classic', 'Massage backrest', 'Revolutionary seat pan'],\n                description: 'Revolutionary seat pan mechanism allows backrest to massage the user\\'s lower back.'\n            },\n            'C60D': {\n                name: 'Steamboat C60D',\n                price: 1770,\n                type: 'operator',\n                style: 'traditional',\n                heightCategory: ['tall'],\n                features: ['Large seat', 'Comfortable reach', 'Padded design'],\n                description: 'Sit down comfortably and still reach your patient with padded comfort.'\n            },\n            'C60ABT': {\n                name: 'Steamboat C60ABT Assistant',\n                price: 2157,\n                type: 'assistant',\n                style: 'traditional',\n                heightCategory: ['tall'],\n                features: ['Large seat', 'High resilience foam', 'All sizes comfort'],\n                description: 'Loved by dental assistants of all shapes and sizes for large seat comfort.'\n            },\n            'C70DS': {\n                name: 'Aspen C70DS',\n                price: 1718,\n                type: 'operator',\n                style: 'traditional',\n                heightCategory: ['small', 'medium'],\n                features: ['Redesigned classic', 'Versatile shape', 'Multiple functions'],\n                description: 'Redesigned classic with more functions and versatile shape design.'\n            },\n            'C70DL': {\n                name: 'Aspen C70DL Large',\n                price: 1718,\n                type: 'operator',\n                style: 'traditional',\n                heightCategory: ['small', 'medium'],\n                features: ['Large seat', 'Maximum comfort', 'Shorter professional friendly'],\n                description: 'Perfect for shorter dental professionals who want maximum comfort and adjustability.'\n            },\n            'C85SD': {\n                name: 'Sterling C85SD',\n                price: 1898,\n                type: 'operator',\n                style: 'traditional',\n                heightCategory: ['medium', 'tall'],\n                features: ['Sterling series quality', 'Simple mobility', 'Versatile'],\n                description: 'Comfort and style with versatility and simple mobility.'\n            },\n            'C85SA': {\n                name: 'Sterling C85SA Assistant',\n                price: 2348,\n                type: 'assistant',\n                style: 'traditional',\n                heightCategory: ['medium', 'tall'],\n                features: ['Premium assistant design', 'All sizes accommodation', 'High-end features'],\n                description: 'Designed for users of all sizes with premium comfort and style.'\n            },\n            'C90SS': {\n                name: 'C90SS Saddle',\n                price: 1108,\n                type: 'operator',\n                style: 'saddle',\n                heightCategory: ['small', 'medium', 'tall'],\n                features: ['Saddle design', 'Versatile functions', 'Redesigned classic'],\n                description: 'Redesigned classic with saddle comfort and versatile functionality.'\n            },\n            'C90SSA': {\n                name: 'C90SSA Assistant Saddle',\n                price: 1557,\n                type: 'assistant',\n                style: 'saddle',\n                heightCategory: ['small', 'medium', 'tall'],\n                features: ['Assistant saddle', 'Versatile positioning', 'Multiple functions'],\n                description: 'Assistant stool with saddle design for versatile positioning.'\n            },\n            'C90SSAB': {\n                name: 'C90SSAB Assistant w\/ Back',\n                price: 1978,\n                type: 'assistant',\n                style: 'saddle',\n                heightCategory: ['small', 'medium', 'tall'],\n                features: ['Saddle with backrest', 'Assistant design', 'Enhanced comfort'],\n                description: 'Assistant stool combining saddle benefits with back support.'\n            },\n            'C90SSB': {\n                name: 'C90SSB Saddle w\/ Back',\n                price: 1512,\n                type: 'operator',\n                style: 'saddle',\n                heightCategory: ['small', 'medium', 'tall'],\n                features: ['English Style Saddle', 'Dual lever adjustment', 'Back support'],\n                description: 'English Style Saddle with dual lever adjustment and back support.'\n            },\n            'C120DM': {\n                name: 'C120DM Traditional',\n                price: 1400,\n                type: 'operator',\n                style: 'traditional',\n                heightCategory: ['small', 'medium'],\n                features: ['Reduces pressure points', 'Forward leaning comfort', 'Ergonomic design'],\n                description: 'Eliminates unhealthy pressure points from traditional chair design.'\n            },\n            'C120DML': {\n                name: 'C120DML Large Traditional',\n                price: 1662,\n                type: 'operator',\n                style: 'traditional',\n                heightCategory: ['small', 'medium'],\n                features: ['Large seat', 'Pressure point reduction', 'Enhanced comfort'],\n                description: 'Large seat version reducing pressure points from hip bones, tailbone, and legs.'\n            },\n            'C120AM': {\n                name: 'C120AM Assistant Traditional',\n                price: 1850,\n                type: 'assistant',\n                style: 'traditional',\n                heightCategory: ['small', 'medium'],\n                features: ['Assistant-specific', 'Pressure point reduction', 'Traditional comfort'],\n                description: 'Assistant version eliminating pressure points while maintaining traditional comfort.'\n            },\n            'C120OML': {\n                name: 'C120OML Mesh Operator',\n                price: 1879,\n                type: 'operator',\n                style: 'traditional',\n                heightCategory: ['small', 'medium'],\n                features: ['Mesh design', 'All sizes recommendation', 'Lightweight'],\n                description: 'Mesh operator stool recommended for users of all sizes with enhanced breathability.'\n            },\n            'C130D': {\n                name: 'Denver C130D',\n                price: 1108,\n                type: 'operator',\n                style: 'saddle',\n                heightCategory: ['small', 'medium', 'tall'],\n                features: ['Ergo-style', 'Seating groove', 'Versatile functions'],\n                description: 'Ergo-style dental operator stool with seating groove for enhanced versatility.'\n            },\n            'C130DB': {\n                name: 'Denver C130DB w\/ Back',\n                price: 1554,\n                type: 'operator',\n                style: 'saddle',\n                heightCategory: ['small', 'medium', 'tall'],\n                features: ['Denver series', 'Back support', 'Versatile design'],\n                description: 'Denver operator stool with back support and versatile functionality.'\n            },\n            'C130A': {\n                name: 'Denver C130A Assistant',\n                price: 1599,\n                type: 'assistant',\n                style: 'saddle',\n                heightCategory: ['small', 'medium', 'tall'],\n                features: ['Ergo style saddle', 'Serene gel foam', 'Dual lever adjustments'],\n                description: 'Denver Assistant ergo style saddle with excellent comfort and dual lever adjustments.'\n            },\n            'C130AB': {\n                name: 'Denver C130AB Assistant w\/ Back',\n                price: 2020,\n                type: 'assistant',\n                style: 'saddle',\n                heightCategory: ['small', 'medium', 'tall'],\n                features: ['Ergo Angle Style', 'Versatile positioning', 'Enhanced functions'],\n                description: 'Ergo Angle Style saddle with enhanced functions for versatile positioning.'\n            }\n        };\n\n        function calculateRecommendation() {\n            const formData = new FormData(document.getElementById('seatinggQuiz'));\n            const answers = {};\n            \n            \/\/ Collect form data\n            for (let [key, value] of formData.entries()) {\n                if (answers[key]) {\n                    if (Array.isArray(answers[key])) {\n                        answers[key].push(value);\n                    } else {\n                        answers[key] = [answers[key], value];\n                    }\n                } else {\n                    answers[key] = value;\n                }\n            }\n\n            \/\/ Validation\n            const requiredFields = ['height', 'role', 'style', 'budget', 'workspace', 'usage'];\n            const missingFields = requiredFields.filter(field => !answers[field]);\n            \n            if (missingFields.length > 0) {\n                alert('Please answer all questions before getting your recommendation.');\n                return;\n            }\n\n            \/\/ Calculate recommendations\n            const recommendations = getRecommendations(answers);\n            displayResults(recommendations, answers);\n        }\n\n        function getRecommendations(answers) {\n            const products = Object.entries(productDatabase);\n            let scored = [];\n\n            for (let [model, product] of products) {\n                let score = 0;\n                let reasons = [];\n\n                \/\/ Height compatibility (high weight)\n                if (product.heightCategory.includes(answers.height)) {\n                    score += 30;\n                    reasons.push(`Perfect height compatibility for ${answers.height} users`);\n                }\n\n                \/\/ Role match (high weight)\n                if (answers.role === 'assistant' && product.type === 'assistant') {\n                    score += 25;\n                    reasons.push('Designed specifically for dental assistants');\n                } else if (answers.role !== 'assistant' && product.type === 'operator') {\n                    score += 25;\n                    reasons.push('Optimized for dental operators');\n                }\n\n                \/\/ Style preference\n                if (answers.style === product.style || answers.style === 'no_preference') {\n                    score += 20;\n                    reasons.push(`Matches your ${product.style} style preference`);\n                } else if (answers.style === 'hybrid' && product.style === 'saddle') {\n                    score += 15;\n                    reasons.push('Saddle design offers hybrid ergonomic benefits');\n                }\n\n                \/\/ Budget consideration\n                let budgetScore = 0;\n                if (answers.budget === 'entry' && product.price <= 800) budgetScore = 15;\n                else if (answers.budget === 'mid' && product.price > 800 && product.price <= 1500) budgetScore = 15;\n                else if (answers.budget === 'premium' && product.price > 1500 && product.price <= 2000) budgetScore = 15;\n                else if (answers.budget === 'luxury' && product.price > 2000) budgetScore = 15;\n                else budgetScore = Math.max(0, 10 - Math.abs(product.price - getBudgetMidpoint(answers.budget)) \/ 200);\n                \n                score += budgetScore;\n                if (budgetScore >= 10) reasons.push('Fits within your budget range');\n\n                \/\/ Usage intensity\n                if (answers.usage === 'intensive' && product.price > 1500) {\n                    score += 10;\n                    reasons.push('Premium features for intensive daily use');\n                } else if (answers.usage === 'heavy' && product.price > 1000) {\n                    score += 8;\n                    reasons.push('Quality construction for heavy daily use');\n                }\n\n                \/\/ Specific needs\n                if (answers.needs) {\n                    const needs = Array.isArray(answers.needs) ? answers.needs : [answers.needs];\n                    needs.forEach(need => {\n                        if (need === 'back_support' && (model.includes('B') || product.features.some(f => f.toLowerCase().includes('back')))) {\n                            score += 8;\n                            reasons.push('Includes back support feature');\n                        }\n                        if (need === 'wide_seat' && (model.includes('L') || product.features.some(f => f.toLowerCase().includes('large')))) {\n                            score += 8;\n                            reasons.push('Features larger seat dimensions');\n                        }\n                        if (need === 'arm_support' && (model.includes('A') && product.type === 'assistant')) {\n                            score += 5;\n                            reasons.push('Assistant model with enhanced support');\n                        }\n                    });\n                }\n\n                scored.push({\n                    model,\n                    product,\n                    score,\n                    reasons\n                });\n            }\n\n            \/\/ Sort by score and return top recommendations\n            scored.sort((a, b) => b.score - a.score);\n            return scored.slice(0, 3);\n        }\n\n        function getBudgetMidpoint(budget) {\n            switch (budget) {\n                case 'entry': return 650;\n                case 'mid': return 1150;\n                case 'premium': return 1750;\n                case 'luxury': return 2200;\n                default: return 1200;\n            }\n        }\n\n        function displayResults(recommendations, answers) {\n            const resultsSection = document.getElementById('results');\n            const primaryRec = document.getElementById('primaryRecommendation');\n            const modelDetails = document.getElementById('modelDetails');\n            const whySection = document.getElementById('whySection');\n\n            \/\/ Primary recommendation\n            const top = recommendations[0];\n            primaryRec.innerHTML = `\n                <h3>🎯 Your Perfect Match<\/h3>\n                <h2>${top.product.name}<\/h2>\n                <p>Based on your responses, this model scores ${Math.round(top.score)}\/100 for your specific needs.<\/p>\n            `;\n\n            \/\/ Model details\n            modelDetails.innerHTML = recommendations.map(rec => `\n                <div class=\"model-card\">\n                    <h4>${rec.product.name}<\/h4>\n                    <div class=\"price-tag\">$${rec.product.price}<\/div>\n                    <p>${rec.product.description}<\/p>\n                    <ul class=\"features-list\">\n                        ${rec.product.features.map(feature => `<li>${feature}<\/li>`).join('')}\n                    <\/ul>\n                    <div style=\"margin-top: 15px;\">\n                        <strong>Why this matches:<\/strong>\n                        <ul style=\"margin-top: 5px; padding-left: 20px;\">\n                            ${rec.reasons.slice(0, 3).map(reason => `<li>${reason}<\/li>`).join('')}\n                        <\/ul>\n                    <\/div>\n                <\/div>\n            `).join('');\n\n            \/\/ Explanation section\n            whySection.innerHTML = `\n                <h3>📋 Your Recommendation Summary<\/h3>\n                <p><strong>Height Category:<\/strong> ${answers.height.charAt(0).toUpperCase() + answers.height.slice(1)} - Models selected for optimal ergonomics<\/p>\n                <p><strong>Professional Role:<\/strong> ${answers.role.charAt(0).toUpperCase() + answers.role.slice(1)} - Seating optimized for your daily tasks<\/p>\n                <p><strong>Style Preference:<\/strong> ${answers.style.replace('_', ' ').charAt(0).toUpperCase() + answers.style.replace('_', ' ').slice(1)} - Matching your comfort preferences<\/p>\n                <p><strong>Budget Range:<\/strong> ${answers.budget.charAt(0).toUpperCase() + answers.budget.slice(1)} - Value-optimized selections<\/p>\n                \n                <div style=\"margin-top: 20px; padding: 15px; background: rgba(255,255,255,0.7); border-radius: 8px;\">\n                    <h4>Next Steps:<\/h4>\n                    <p>1. <strong>Review<\/strong> the recommended models above<\/p>\n                    <p>2. <strong>Consider<\/strong> visiting our showroom for a test sit<\/p>\n                    <p>3. <strong>Contact<\/strong> our specialists for personalized fitting<\/p>\n                    <p>4. <strong>Explore<\/strong> upholstery and customization options<\/p>\n                <\/div>\n            `;\n\n            resultsSection.style.display = 'block';\n            resultsSection.scrollIntoView({ behavior: 'smooth' });\n        }\n    <\/script>\n<\/body>\n<\/html>","color_scheme":"","section_width":"page-width","padding-block-start":0,"padding-block-end":0}},"crown_seating_quiz_bGdLAG":{"type":"crown-seating-quiz","name":"Crown Seating Quiz","settings":{"heading":"Crown Seating","subheading":"Professional Seating Selection","description":"Find your perfect dental professional seating solution with our comprehensive assessment. Answer a few questions to get personalized recommendations based on your height, role, and workspace needs.","primary_color":"#667eea","accent_color":"#764ba2"}}},"order":["main","custom_liquid_4nHQBQ","crown_seating_quiz_bGdLAG"]}